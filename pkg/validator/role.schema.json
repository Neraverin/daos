{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daos.local/schemas/role.schema.json",
  "title": "Role Schema",
  "description": "Schema for validating role YAML configuration files",
  "type": "object",
  "required": ["Version", "Role"],
  "properties": {
    "Version": {
      "type": "string",
      "pattern": "^v[0-9]+$",
      "description": "Schema version (must start with 'v' followed by number)"
    },
    "Role": {
      "type": "object",
      "required": ["TypeId", "Name", "Version"],
      "properties": {
        "TypeId": {
          "type": "string",
          "minLength": 1,
          "description": "Role type identifier"
        },
        "Name": {
          "type": "string",
          "minLength": 1,
          "description": "Role name"
        },
        "Version": {
          "type": "string",
          "minLength": 1,
          "description": "Role version"
        },
        "Description": {
          "type": "string",
          "description": "Role description (optional)"
        },
        "Definitions": {
          "type": "object",
          "properties": {
            "ImageFile": {
              "type": "string",
              "description": "Path to role image tar file"
            },
            "Images": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["Id"],
                "properties": {
                  "Id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Image identifier"
                  }
                }
              }
            },
            "TemplateFiles": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "Template file path"
              }
            }
          }
        }
      }
    }
  }
}
